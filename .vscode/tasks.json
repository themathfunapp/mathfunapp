{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Flutter: analyze",
      "type": "shell",
      "command": "flutter",
      "args": ["analyze"],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {}
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter: test",
      "type": "shell",
      "command": "flutter",
      "args": ["test"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Flutter: build web (Wasm dry-run kapalı)",
      "type": "shell",
      "command": "flutter",
      "args": ["build", "web", "--no-wasm-dry-run"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ]
}
