# Copy to key.properties (same folder) and fill in. Never commit key.properties.
# Create keystore: keytool -genkey -v -keystore upload-keystore.jks -keyalg RSA -keysize 2048 -validity 10000 -alias upload

storePassword=your-store-password
keyPassword=your-key-password
keyAlias=upload
# Path is relative to android/app/ — keystore in android/ folder:
storeFile=../upload-keystore.jks
