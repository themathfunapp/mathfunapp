rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function isMtnStylePlayerId(id) {
      return id is string && id.matches('^MTN[1-9][0-9]{9}$');
    }

    function membersDoc(parentUid) {
      return get(/databases/$(database)/documents/users/$(parentUid)/family/members);
    }

    /// `family/members` belgesindeki `childUserIds` (FamilyService).
    function parentLinkedChild(parentUid, childUid) {
      return membersDoc(parentUid).data != null
        && membersDoc(parentUid).data.keys().hasAny(['childUserIds'])
        && childUid in membersDoc(parentUid).data.childUserIds;
    }

    function userDocPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userFamilyAnchor(uid) {
      return exists(userDocPath(uid))
        && 'familyAnchorParentUid' in get(userDocPath(uid)).data.keys()
        ? get(userDocPath(uid)).data.familyAnchorParentUid
        : '';
    }

    function shareFamilyAnchor(a, b) {
      return userFamilyAnchor(a) != ''
        && userFamilyAnchor(a) == userFamilyAnchor(b);
    }

    function familyMayNotify(fromUid, toUid) {
      return fromUid != toUid && (
        parentLinkedChild(fromUid, toUid)
        || parentLinkedChild(toUid, fromUid)
        || shareFamilyAnchor(fromUid, toUid)
      );
    }

    function parentMaySetChildFamilyAnchor(childUid) {
      return request.auth.uid != childUid
        && parentLinkedChild(request.auth.uid, childUid)
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['familyAnchorParentUid', 'updatedAt'])
        && request.resource.data.familyAnchorParentUid == request.auth.uid;
    }

    function isDuelParticipant(data) {
      return signedIn()
        && (
          (data.keys().hasAny(['participantUserIds']) && request.auth.uid in data.participantUserIds)
          || request.auth.uid == data.hostUserId
          || request.auth.uid == data.guestUserId
        );
    }

    // --- Yalnızca Cloud Functions (Admin SDK) ---
    match /pinResetCodes/{docId} {
      allow read, write: if false;
    }

    match /mail/{docId} {
      allow read, write: if false;
    }

    // --- Misafir: Firebase Auth yok; MTN kimliği ile ilk kayıt ---
    match /guests/{guestId} {
      allow create: if request.auth == null
        && guestId == request.resource.data.uid
        && request.resource.data.isGuest == true;
      allow read: if signedIn();
      allow delete: if signedIn();
      allow update: if false;
    }

    // --- Arkadaş düello daveti ---
    match /friendDuelInvites/{inviteId} {
      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.toUserId is string
        && request.resource.data.toUserId != request.auth.uid
        && request.resource.data.status == 'pending';

      allow read: if signedIn()
        && (resource.data.fromUserId == request.auth.uid
            || resource.data.toUserId == request.auth.uid);

      allow delete: if signedIn()
        && (resource.data.fromUserId == request.auth.uid
            || (resource.data.toUserId == request.auth.uid
                && resource.data.status == 'pending'));

      allow update: if false;
    }

    // --- Arkadaşlık isteği ---
    match /friendRequests/{requestId} {
      allow create: if signedIn()
        && request.resource.data.senderId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.receiverId is string
        && request.resource.data.receiverId != request.auth.uid;

      allow read: if signedIn()
        && (resource.data.senderId == request.auth.uid
            || resource.data.receiverId == request.auth.uid);

      allow update: if signedIn()
        && resource.data.senderId == request.resource.data.senderId
        && resource.data.receiverId == request.resource.data.receiverId
        && resource.data.status == 'pending'
        && request.resource.data.status in ['accepted', 'rejected']
        && resource.data.receiverId == request.auth.uid;

      allow delete: if signedIn() && resource.data.senderId == request.auth.uid;
    }

    // --- Kullanıcı kökü + alt koleksiyonlar ---
    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() && request.auth.uid == userId;
      allow delete: if signedIn() && request.auth.uid == userId;
      allow update: if signedIn() && (
        request.auth.uid == userId
        || parentMaySetChildFamilyAnchor(userId)
      );

      match /friends/{friendId} {
        allow read: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == friendId);
        allow create, update, delete: if signedIn()
          && (request.auth.uid == userId || request.auth.uid == friendId);
      }

      match /rewards/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /stats/{docId} {
        allow read: if signedIn() && (
          request.auth.uid == userId
          || parentLinkedChild(request.auth.uid, userId)
        );
        allow write: if signedIn() && (
          request.auth.uid == userId
          || parentLinkedChild(request.auth.uid, userId)
        );
      }

      match /badges/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /game_stats/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /game_history/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /family/members {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      match /family/{docId} {
        allow read: if signedIn() && (
          request.auth.uid == userId
          || parentLinkedChild(userId, request.auth.uid)
        );
        allow write: if signedIn() && (
          request.auth.uid == userId
          || parentLinkedChild(userId, request.auth.uid)
        );
      }

      match /private/fcm/{docId} {
        allow read, write: if signedIn() && request.auth.uid == userId;
      }

      // Uygulama içi bildirim kutusu (aile üyeleri isim değişikliği vb.)
      match /in_app_notifications/{docId} {
        allow read, update, delete: if signedIn() && request.auth.uid == userId;

        allow create: if signedIn()
          && request.auth.uid != userId
          && familyMayNotify(request.auth.uid, userId)
          && (
            (
              request.resource.data.keys().hasOnly([
                'type', 'fromUid', 'oldDisplayName', 'newDisplayName', 'read', 'createdAt'
              ])
              && request.resource.data.type == 'display_name_changed'
              && request.resource.data.fromUid == request.auth.uid
              && request.resource.data.oldDisplayName is string
              && request.resource.data.newDisplayName is string
              && request.resource.data.oldDisplayName.size() <= 120
              && request.resource.data.newDisplayName.size() <= 120
              && request.resource.data.read == false
            )
            ||
            (
              request.resource.data.keys().hasOnly([
                'type', 'fromUid', 'oldDisplayName', 'newDisplayName', 'read', 'createdAt', 'inviteId'
              ])
              && request.resource.data.type == 'family_remote_duel_invite_timeout'
              && request.resource.data.fromUid == request.auth.uid
              && request.resource.data.oldDisplayName is string
              && request.resource.data.oldDisplayName.size() > 0
              && request.resource.data.oldDisplayName.size() <= 120
              && request.resource.data.newDisplayName == ''
              && request.resource.data.read == false
              && request.resource.data.inviteId is string
              && request.resource.data.inviteId.size() > 0
              && exists(/databases/$(database)/documents/familyRemoteDuelInvites/$(request.resource.data.inviteId))
              && docId == 'frd_invite_timeout_' + get(/databases/$(database)/documents/familyRemoteDuelInvites/$(request.resource.data.inviteId)).data.sessionId
              && get(/databases/$(database)/documents/familyRemoteDuelInvites/$(request.resource.data.inviteId)).data.fromUserId == userId
              && get(/databases/$(database)/documents/familyRemoteDuelInvites/$(request.resource.data.inviteId)).data.toUserId == request.auth.uid
              && get(/databases/$(database)/documents/familyRemoteDuelInvites/$(request.resource.data.inviteId)).data.status == 'expired'
            )
          );
      }
    }

    // --- Uzaktan aile düellosu ---
    match /familyRemoteDuelSessions/{sessionId} {
      allow read: if signedIn() && isDuelParticipant(resource.data);

      allow create: if signedIn()
        && request.resource.data.hostUserId == request.auth.uid
        && request.resource.data.invitedUserIds is list
        && request.resource.data.invitedUserIds.size() > 0
        && membersDoc(request.auth.uid).data != null
        && membersDoc(request.auth.uid).data.keys().hasAny(['childUserIds'])
        && request.resource.data.invitedUserIds.hasOnly(membersDoc(request.auth.uid).data.childUserIds)
        && request.resource.data.participantUserIds is list
        && request.resource.data.participantUserIds.hasAll(request.resource.data.invitedUserIds)
        && request.auth.uid in request.resource.data.participantUserIds
        && request.resource.data.acceptedUserIds is list
        && request.resource.data.correctCounts is map
        && request.resource.data.expiresAtMs is int
        && request.resource.data.status == 'waiting_accept';

      allow update: if signedIn()
        && isDuelParticipant(resource.data)
        && request.resource.data.hostUserId == resource.data.hostUserId
        && request.resource.data.invitedUserIds == resource.data.invitedUserIds
        && request.resource.data.participantUserIds == resource.data.participantUserIds
        && request.resource.data.expiresAtMs == resource.data.expiresAtMs
        && request.resource.data.questions == resource.data.questions
        && request.resource.data.topicKey == resource.data.topicKey
        && request.resource.data.questionSeed == resource.data.questionSeed;

      allow delete: if false;
    }

    match /familyRemoteDuelInvites/{inviteId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);

      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.expiresAtMs is int
        && parentLinkedChild(
          request.resource.data.fromUserId,
          request.resource.data.toUserId
        );

      allow update: if signedIn() && (
        (request.auth.uid == resource.data.toUserId
          && resource.data.status == 'pending'
          && request.resource.data.fromUserId == resource.data.fromUserId
          && request.resource.data.toUserId == resource.data.toUserId
          && request.resource.data.sessionId == resource.data.sessionId
          && request.resource.data.expiresAtMs == resource.data.expiresAtMs
          && request.resource.data.status in ['accepted', 'declined', 'expired'])
        ||
        (request.auth.uid == resource.data.fromUserId
          && resource.data.status == 'pending'
          && request.resource.data.expiresAtMs == resource.data.expiresAtMs
          && request.resource.data.status in ['cancelled', 'expired'])
      );

      allow delete: if false;
    }

    // --- Hikâye modu: ebeveyn → ailedeki çocuğa bölüm daveti ---
    match /familyStoryInviteSessions/{sessionId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid in resource.data.invitedUserIds);

      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.invitedUserIds is list
        && request.resource.data.acceptedUserIds is list
        && request.resource.data.expiresAtMs is int;

      allow update: if signedIn()
        && (
          (
            request.auth.uid == resource.data.fromUserId
            && request.resource.data.fromUserId == resource.data.fromUserId
            && request.resource.data.invitedUserIds == resource.data.invitedUserIds
            && request.resource.data.status in ['pending', 'active', 'cancelled', 'expired']
          )
          ||
          (
            request.auth.uid in resource.data.invitedUserIds
            && request.resource.data.fromUserId == resource.data.fromUserId
            && request.resource.data.invitedUserIds == resource.data.invitedUserIds
            && request.resource.data.status in ['pending', 'active', 'cancelled', 'expired']
          )
        );

      allow delete: if false;
    }

    match /familyStoryInvites/{inviteId} {
      allow read: if signedIn()
        && (request.auth.uid == resource.data.fromUserId
            || request.auth.uid == resource.data.toUserId);

      allow create: if signedIn()
        && request.resource.data.fromUserId == request.auth.uid
        && request.resource.data.status == 'pending'
        && request.resource.data.sessionId is string
        && request.resource.data.expiresAtMs is int
        && request.resource.data.worldId is string
        && request.resource.data.chapterId is string
        && request.resource.data.worldNameKey is string
        && request.resource.data.chapterNameKey is string
        && request.resource.data.toUserId is string
        && parentLinkedChild(
          request.resource.data.fromUserId,
          request.resource.data.toUserId
        );

      allow update: if signedIn()
        && resource.data.status == 'pending'
        && request.resource.data.fromUserId == resource.data.fromUserId
        && request.resource.data.toUserId == resource.data.toUserId
        && request.resource.data.worldId == resource.data.worldId
        && request.resource.data.chapterId == resource.data.chapterId
        && request.resource.data.sessionId == resource.data.sessionId
        && request.resource.data.expiresAtMs == resource.data.expiresAtMs
        && (
          (
            request.auth.uid == resource.data.toUserId
            && request.resource.data.status in ['accepted', 'declined', 'expired', 'cancelled']
          )
          ||
          (
            request.auth.uid == resource.data.fromUserId
            && resource.data.status in ['declined', 'expired', 'cancelled']
            && request.resource.data.status in ['declined', 'expired', 'cancelled']
          )
        );

      allow delete: if false;
    }

    // --- Oyun ilerlemesi (kayıtlı kullanıcı veya misafir MTN belge kimliği) ---
    match /story_progress/{docId} {
      allow read, write: if (signedIn() && request.auth.uid == docId)
        || (request.auth == null && isMtnStylePlayerId(docId));
    }

    match /mini_game_progress/{docId} {
      allow read, write: if (signedIn() && request.auth.uid == docId)
        || (request.auth == null && isMtnStylePlayerId(docId));
    }

    match /user_mechanics/{docId} {
      allow read, write: if signedIn() && request.auth.uid == docId;
    }

    match /user_quests/{userId}/active/{questId} {
      allow read, write: if (signedIn() && request.auth.uid == userId)
        || (request.auth == null && isMtnStylePlayerId(userId));
    }

    // Günlük challenge şablonu — istemci oluşturur; kötüye kullanımı azaltmak için ileride CF önerilir.
    match /daily_challenges/{dateKey} {
      allow read: if signedIn();
      allow create, update: if signedIn();
      allow delete: if false;
    }

    match /user_challenges/{docId} {
      allow read, write: if signedIn()
        && docId.matches('^' + request.auth.uid + '_.+');
    }

    match /purchases/{purchaseId} {
      allow create: if signedIn()
        && request.resource.data.userId == request.auth.uid;
      allow read: if signedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // Dünya sıralaması: liste herkese açık okunur (orderBy sorgusu); yazma yalnızca kendi UID belgesi.
    // Not: read için signedIn() bazı istemcilerde token senkronu gecikince permission-denied verebiliyor.
    match /worldCoinsLeaderboard/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.coins is int
        && request.resource.data.coins >= 0
        && request.resource.data.coins < 1000000000
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 100;
      allow delete: if signedIn() && request.auth.uid == userId;
    }

    match /worldDiamondsLeaderboard/{userId} {
      allow read: if true;
      allow create, update: if signedIn()
        && request.auth.uid == userId
        && request.resource.data.diamonds is int
        && request.resource.data.diamonds >= 0
        && request.resource.data.diamonds < 1000000000
        && request.resource.data.displayName is string
        && request.resource.data.displayName.size() > 0
        && request.resource.data.displayName.size() <= 100;
      allow delete: if signedIn() && request.auth.uid == userId;
    }
  }
}
